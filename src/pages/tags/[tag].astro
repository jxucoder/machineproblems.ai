---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const problems = await getCollection('problems', ({ data }) => !data.draft);
  const tags = new Set<string>();
  for (const p of problems) {
    for (const tag of p.data.tags) tags.add(tag);
  }
  return [...tags].map((tag) => ({ params: { tag } }));
}

const { tag } = Astro.params;
const problems = await getCollection('problems', ({ data }) => !data.draft);
const filtered = problems
  .filter((p) => p.data.tags.includes(tag!))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<Base title={`Tag: ${tag}`} description={`Problems tagged with ${tag}`}>
  <div class="max-w-3xl mx-auto px-5 pt-10 pb-20">
    <a href="/tags" class="text-[13px] text-text-secondary hover:text-text transition-colors">&larr; Tags</a>
    <h1 class="text-2xl font-semibold tracking-tight mt-4 mb-8">{tag}</h1>
    <div class="border-t border-border">
      {filtered.map((p) => (
        <a href={`/${p.slug}`} class="group block py-4 border-b border-border">
          <span class="text-[15px] group-hover:underline">{p.data.title}</span>
          <p class="text-sm text-text-secondary mt-1">{p.data.description}</p>
        </a>
      ))}
    </div>
  </div>
</Base>
